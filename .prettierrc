{
    "plugins": ["@prettier/plugin-php", "@shufo/prettier-plugin-blade"],
    "printWidth": 120,
    "overrides": [
        {
            "files": ["*.blade.php"],
            "options": {
                "parser": "blade",
                "tabWidth": 4,
                "sortTailwindcssClasses": true,
                "sortHtmlAttributes": "code-guide"
            }
        }
    ]
}
